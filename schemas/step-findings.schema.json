{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/TODO/conwrt/schemas/step-findings.json",
  "title": "Step Findings",
  "description": "Structured findings produced by each conwrt step.",
  "type": "object",
  "additionalProperties": false,
  "required": ["step_id", "step_name", "started_at", "completed_at", "status", "summary"],
  "properties": {
    "step_id": {
      "type": "string",
      "pattern": "^step-[0-9]{2}$",
      "description": "Step identifier e.g. step-01"
    },
    "step_name": { "type": "string", "description": "Human-readable step name" },
    "started_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}[T ][0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})?$" },
    "completed_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}[T ][0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})?$" },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "failed"],
      "description": "Step completion status"
    },
    "summary": { "type": "string", "description": "Human-readable summary of findings" },
    "candidates": {
      "type": "array",
      "description": "Identified device candidates",
      "items": { "type": "object" }
    },
    "evidence_files": {
      "type": "array",
      "description": "Relative paths to redacted evidence files",
      "items": { "type": "string" }
    },
    "next_step_input": {
      "type": "object",
      "description": "Input context for the next step",
      "additionalProperties": true
    }
  }
}
