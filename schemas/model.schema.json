{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amperstrand.github.io/conwrt/schemas/model.schema.json",
  "title": "conwrt device model",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "vendor", "description", "openwrt", "flash_methods", "capabilities"],
  "properties": {
    "id": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9_.-]+$"},
    "vendor": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "openwrt": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target", "profile", "version"],
      "properties": {
        "target": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+$"},
        "device": {"type": "string"},
        "profile": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "default_ip": {"type": "string", "minLength": 1}
      }
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string", "enum": ["ethernet", "wifi", "usb", "lte", "cellular", "serial"]},
      "uniqueItems": true
    },
    "flash_methods": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["description"],
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "recovery_ip": {"type": "string"},
          "client_ip": {"type": "string"},
          "upload_endpoint": {"type": "string"},
          "command": {"type": "string"},
          "flash_time_seconds": {"type": "integer", "minimum": 0},
          "silence_timeout": {"type": "integer", "minimum": 0}
        }
      }
    },
    "tested_hardware": {"type": "object"},
    "signatures": {"type": "object"},
    "hardware": {"type": "object"},
    "mac_oui": {"type": "array", "items": {"type": "string"}}
  }
}
