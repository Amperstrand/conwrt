#!/bin/sh /etc/rc.common
# poe-watchdog.init — procd init for PoE overcurrent watchdog
# Deploy to: /etc/init.d/poe-watchdog

START=96
STOP=9
USE_PROCD=1
PROG=/usr/sbin/poe-watchdog

start_service() {
	procd_open_instance "poe-watchdog"
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "poe"
}
