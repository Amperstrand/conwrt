#!/bin/sh /etc/rc.common
# poe-monitor.init — procd init for PoE monitoring export
# Deploy to: /etc/init.d/poe-monitor

START=97
STOP=8
USE_PROCD=1
PROG=/usr/sbin/poe-monitor

start_service() {
	procd_open_instance "poe-monitor"
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "poe"
}
