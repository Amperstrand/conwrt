{
  "id": "glinet_gl-ar300m-nand",
  "vendor": "GL.iNet",
  "description": "AR300M / AR300M-Ext / AR300MD (NAND boot)",
  "openwrt": {
    "target": "ath79/nand",
    "device": "glinet,gl-ar300m-nand",
    "default_ip": "192.168.8.1",
    "profile": "glinet_gl-ar300m-nand",
    "version": "24.10.2"
  },
  "hardware": {
    "soc": "AR9344 (MIPS 24Kc) @ 533MHz",
    "flash": "NAND 128MB + NOR 16MB",
    "ram": "128MB DDR2",
    "ethernet_ports": "2x 10/100 (1 WAN + 1 LAN)",
    "wifi": "2.4GHz 802.11b/g/n (AR9344 integrated)",
    "usb": "1x USB 2.0 Type-A",
    "power": "5V/2A micro-USB"
  },
  "mac_oui": [
    "94:83:C4"
  ],
  "stock_default_ip": "192.168.8.1",
  "flash_methods": {
    "sysupgrade": {
      "description": "SSH sysupgrade from existing OpenWrt",
      "command": "sysupgrade -n /tmp/firmware.bin",
      "exit_code": 246
    }
  }
