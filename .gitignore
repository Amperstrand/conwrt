# --- Personal / device-specific data (never commit) ---
config.toml
data/
.env
secrets/
backups/

# --- Runtime artifacts ---
# runs/ contains per-device session data — all gitignored
# (the .gitkeep is tracked via git add -f)
runs/
!runs/.gitkeep

# captures/ contains pcap files for boot sequence analysis — never commit
captures/
!captures/.gitkeep

# --- Node modules ---
node_modules/

# --- macOS ---
.DS_Store

# --- Certificates and keys ---
*.pem
*.key
wireguard/
*.wg*.conf

# --- IDE ---
.cursor/

# --- OpenCode / tooling workspaces ---
.opencode/
.playwright-mcp/
.sisyphus/
.omo/

# --- Images (never commit — use look_at or read tool instead) ---
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
*.tif
*.tiff

# --- Stray files ---
device-identification-notes.md
linksys-velop-*.png
captures/

# --- Firmware images at repo root (use images/ or data/) ---
/*.bin
/*.img
/*.trx
/*.fit

# --- Python ---
__pycache__/
*.pyc
*.egg-info/
.venv/

# --- Firmware image cache ---
images/

# --- Proprietary stock firmware binaries (re-extract with firmware/extract.sh) ---
firmware/stock_v290/*.ko
firmware/stock_v290/*.so*
firmware/stock_v290/cli
firmware/stock_v290/*.bin
firmware/stock_v290/*.bix

# --- PII redaction tools (local-only, not for repo) ---
scripts/redact-pii.sh
